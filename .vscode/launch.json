{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Debug Eureka",
      "request": "launch",
      "cwd": "${workspaceFolder}/eureka",
      "mainClass": "cl.triskeledu.eureka.RitmoticketEurekaApplication",
      "projectName": "cl-triskeledu-eureka",
      "envFile": "${workspaceFolder}/.env",
      "vmArgs": "-Dcom.sun.management.jmxremote=false"
    },
    {
      "type": "java",
      "name": "Debug API Gateway",
      "request": "launch",
      "cwd": "${workspaceFolder}/api-gateway",
      "mainClass": "cl.triskeledu.gateway.BibliotecaGatewayApplication",
      "projectName": "cl-triskeledu-gateway",
      "vmArgs": "-Dcom.sun.management.jmxremote.port=10900 -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false",
      "preLaunchTask": "Wait for Eureka"
    },
